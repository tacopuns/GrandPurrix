    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "CalculateSlope",
    "m_FunctionSource": "",
    "m_FunctionBody": "float surfaceAngle = acos(dot(normalWS, float3(0,1,0)) * 2.0 - 1.0) * 57.29578;\r\n\r\nfloat start = surfaceAngle - threshold;\nfloat end = threshold - 15;\r\n\t\r\nslope = saturate((end - start) / (end - threshold));"
}

